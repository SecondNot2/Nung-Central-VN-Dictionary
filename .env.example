# -----------------------------------------------------------------------------
# NungDic Environment Variables Example
# -----------------------------------------------------------------------------

# Supabase Configuration
# Required for authentication, database access, and storage.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Translation Configuration via 9Router (server-side, keep secrets off the client)
# Set these in server/runtime env vars, NOT prefixed with VITE.
ROUTER_API_KEY=your-9router-api-key
ROUTER_BASE_URL=http://localhost:20128/v1
ROUTER_MODEL=gc/gemini-2.5-pro
ROUTER_VISION_MODEL=gc/gemini-2.5-pro

# Optional: Environment mode
# VITE_APP_ENV=development
