# -----------------------------------------------------------------------------
# NungDic Environment Variables Example
# -----------------------------------------------------------------------------

# Supabase Configuration
# Required for authentication, database access, and storage.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Translation Configuration (server-side, keep secrets off the client)
# Local dev: run 9Router locally and keep ROUTER_* values below.
# Production on Vercel: prefer LLM_* and point them to a reachable HTTPS endpoint.
# Examples:
# - Self-hosted 9Router on a VPS/container: LLM_BASE_URL=https://llm.example.com/v1
# - Any OpenAI-compatible remote gateway/provider
LLM_API_KEY=your-production-llm-api-key
LLM_BASE_URL=https://your-reachable-llm-endpoint/v1
LLM_MODEL=NungDic
LLM_VISION_MODEL=NungDic

# Local 9Router fallback for development
ROUTER_API_KEY=your-9router-api-key
ROUTER_BASE_URL=http://localhost:20128/v1
# Production should set this explicitly to a model that exists in your 9Router instance
# and has an active provider connection.
ROUTER_MODEL=NungDic
ROUTER_VISION_MODEL=NungDic

# Optional: Environment mode
# VITE_APP_ENV=development
